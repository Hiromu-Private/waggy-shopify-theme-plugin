531884c4498cf173393fcc01c635341053065f5e305b07a083481754905dfc16:{"__metadata":{"version":0.1},"root":{"steps":[{"step_id":"01KRH1VGSNTTKW2ZA118X3HW41","step_position":[0,0],"config_field_values":[],"task_id":"shopify::admin::order_paid","task_version":"0.1","task_type":"TRIGGER","description":null,"note":null,"name":null},{"step_id":"01KRH1YZMW67G6M5B77KEQ05Q0","step_position":[0,180],"config_field_values":[{"config_field_id":"input","value":"query {\n  order {\n    id\n    customer { id }\n    currentSubtotalPriceSet {\n      shopMoney { amount }\n    }\n    lineItems {\n      product { tags }\n    }\n  }\n}"},{"config_field_id":"script","value":"export default function main(input) {\n  const order = input.order;\n\n  // Guest order: skip\n  if (!order || !order.customer || !order.customer.id) {\n    return { eligible: false, couponAmount: null, grantedAt: null };\n  }\n\n  // Furniture tag check (case-sensitive, exact match)\n  const lineItems = order.lineItems || [];\n  const hasFurniture = lineItems.some(function (li) {\n    if (!li || !li.product || !li.product.tags) return false;\n    return li.product.tags.indexOf(\"Furniture\") !== -1;\n  });\n\n  if (!hasFurniture) {\n    return { eligible: false, couponAmount: null, grantedAt: null };\n  }\n\n  // Amount tier\n  const subtotalStr = order.currentSubtotalPriceSet && order.currentSubtotalPriceSet.shopMoney\n    ? order.currentSubtotalPriceSet.shopMoney.amount\n    : \"0\";\n  const subtotal = parseFloat(subtotalStr);\n\n  let couponAmount;\n  if (subtotal < 100000) {\n    couponAmount = 2000;\n  } else if (subtotal < 200000) {\n    couponAmount = 3000;\n  } else if (subtotal < 300000) {\n    couponAmount = 5000;\n  } else if (subtotal < 500000) {\n    couponAmount = 8000;\n  } else {\n    couponAmount = 10000;\n  }\n\n  // Today YYYY-MM-DD (UTC; Shopify Flow runs in UTC. Acceptable for JPY shop)\n  const now = new Date();\n  const yyyy = now.getUTCFullYear();\n  const mm = String(now.getUTCMonth() + 1).padStart(2, \"0\");\n  const dd = String(now.getUTCDate()).padStart(2, \"0\");\n  const grantedAt = yyyy + \"-\" + mm + \"-\" + dd;\n\n  return { eligible: true, couponAmount: couponAmount, grantedAt: grantedAt };\n}"},{"config_field_id":"output_schema","value":"\"Output of Thanks Coupon grant evaluation\"\ntype Output {\n  \"Whether the order is eligible for a Thanks Coupon\"\n  eligible: Boolean!\n  \"Coupon amount in JPY (2000/3000/5000/8000/10000), null when not eligible\"\n  couponAmount: Int\n  \"Today's date in YYYY-MM-DD\"\n  grantedAt: String\n}"}],"task_id":"shopify::flow::run_code","task_version":"0.1","task_type":"ACTION","description":null,"note":null,"name":"Run code"},{"step_id":"01KRH26H0QVSDRPDQ539JWA3EH","step_position":[0,280],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"01KRH28EGTA22BKEXXZX8F40V9\",\"lhs\":{\"uuid\":\"01KRH275RMHHHKCZ28M18TD8GD\",\"parent_uuid\":\"01KRH28EGTA22BKEXXZX8F40V9\",\"lhs\":{\"uuid\":\"01KRH28EGTHZDYBQWYH2M7KPRS\",\"parent_uuid\":\"01KRH275RMHHHKCZ28M18TD8GD\",\"value\":\"runCode.eligible\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"runCode.eligible\"},\"rhs\":{\"uuid\":\"01KRH28H6SAGGX6J8G7ZA6GYCM\",\"parent_uuid\":\"01KRH275RMHHHKCZ28M18TD8GD\",\"value\":\"true\",\"comparison_value_type\":\"LiteralValue\"},\"value_type\":\"EnvironmentScalarDefinition:Boolean\",\"operator\":\"==\",\"operation_type\":\"Comparison\"},\"operator\":\"AND\",\"operation_type\":\"LogicalExpression\"}"}],"task_id":"shopify::flow::condition","task_version":"0.1","task_type":"CONDITION","description":null,"note":null,"name":null},{"step_id":"01KRH2CH1FPF8PR9DSNAYES55D","step_position":[-160,440],"config_field_values":[{"config_field_id":"customer_id","value":"{\"value\":\"\",\"default_value\":\"order.customer.id\"}"},{"config_field_id":"metafield","value":"{\"namespace\":\"custom\",\"key\":\"thanks_coupon_amount\",\"type\":\"number_integer\"}"},{"config_field_id":"value","value":"{{runCode.couponAmount}}"}],"task_id":"shopify::admin::add_customer_metafield","task_version":"1.0","task_type":"ACTION","description":null,"note":null,"name":null},{"step_id":"01KRH2MMZHA47NHHX9EM3W34F6","step_position":[-160,600],"config_field_values":[{"config_field_id":"customer_id","value":"{\"value\":\"\",\"default_value\":\"order.customer.id\"}"},{"config_field_id":"metafield","value":"{\"namespace\":\"custom\",\"key\":\"thanks_coupon_granted_at\",\"type\":\"date\"}"},{"config_field_id":"value","value":"{{runCode.grantedAt}}"}],"task_id":"shopify::admin::add_customer_metafield","task_version":"1.0","task_type":"ACTION","description":null,"note":null,"name":null}],"links":[{"from_step_id":"01KRH1VGSNTTKW2ZA118X3HW41","from_port_id":"output","to_step_id":"01KRH1YZMW67G6M5B77KEQ05Q0","to_port_id":"input"},{"from_step_id":"01KRH1YZMW67G6M5B77KEQ05Q0","from_port_id":"output","to_step_id":"01KRH26H0QVSDRPDQ539JWA3EH","to_port_id":"input"},{"from_step_id":"01KRH26H0QVSDRPDQ539JWA3EH","from_port_id":"true","to_step_id":"01KRH2CH1FPF8PR9DSNAYES55D","to_port_id":"input"},{"from_step_id":"01KRH2CH1FPF8PR9DSNAYES55D","from_port_id":"output","to_step_id":"01KRH2MMZHA47NHHX9EM3W34F6","to_port_id":"input"}],"patched_fields":[],"variables":[],"note":null,"vertical_layout_enabled":true,"workflow_name":"Thanks Coupon — Grant"}}