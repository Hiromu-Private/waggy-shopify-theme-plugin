c78eef302dfd1773803942dc040b4431c6b18386a87b1ef43c32496fa709fcac:{"__metadata":{"version":0.1},"root":{"steps":[{"step_id":"01KRH0HXFK3DP4AWBEJWB171CN","step_position":[0,0],"config_field_values":[],"task_id":"shopify::admin::order_created","task_version":"0.1","task_type":"TRIGGER","description":null,"note":null,"name":null},{"step_id":"01KRH0Q4PH2A433VP343HSWVRC","step_position":[0,200],"config_field_values":[{"config_field_id":"input","value":"query {\n  order {\n    id\n    customer { id }\n    discountCodes\n  }\n}"},{"config_field_id":"script","value":"export default function main(input) {\n  const thanksCodes = [\n    \"THANKS2000\",\n    \"THANKS3000\",\n    \"THANKS5000\",\n    \"THANKS8000\",\n    \"THANKS10000\"\n  ];\n\n  const order = input.order;\n\n  // Guest order: skip\n  if (!order || !order.customer || !order.customer.id) {\n    return { hasMatch: false };\n  }\n\n  const codes = order.discountCodes || [];\n  const hasMatch = codes.some(function (code) {\n    return thanksCodes.indexOf(String(code).toUpperCase()) !== -1;\n  });\n\n  return { hasMatch: hasMatch };\n}"},{"config_field_id":"output_schema","value":"\"Output of Thanks Coupon clear evaluation\"\ntype Output {\n  \"Whether the order matches Thanks Coupon clear conditions\"\n  hasMatch: Boolean!\n}"}],"task_id":"shopify::flow::run_code","task_version":"0.1","task_type":"ACTION","description":null,"note":null,"name":"Run code"},{"step_id":"01KRH0Z7SW8BFVTFW3QWP5CCZ9","step_position":[0,300],"config_field_values":[{"config_field_id":"condition","value":"{\"uuid\":\"01KRH12PPHQKTKBK6KWZ5YJ52Y\",\"lhs\":{\"uuid\":\"01KRH1155840WQCA214C15VEZ8\",\"parent_uuid\":\"01KRH12PPHQKTKBK6KWZ5YJ52Y\",\"lhs\":{\"uuid\":\"01KRH12PPHJAJVMT358436M20G\",\"parent_uuid\":\"01KRH1155840WQCA214C15VEZ8\",\"value\":\"runCode.hasMatch\",\"comparison_value_type\":\"EnvironmentValue\",\"full_environment_path\":\"runCode.hasMatch\"},\"rhs\":{\"uuid\":\"01KRH12SG6TD2XY7Q1F0AS7HZC\",\"parent_uuid\":\"01KRH1155840WQCA214